#I've generated this entire file using Gemini

# ==========================================
# 1. Environment Variables & Secrets
# NEVER COMMIT THESE. 
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Allow example files so reviewers know what variables are needed
!.env.example
!.env.sample

# ==========================================
